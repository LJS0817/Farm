    [\r\n    {\r\n      \"Action\": \"MoveTo\",\r\n      \"TargetGridPos\": { \"x\":
    0, \"y\": 0 },\r\n      \"Crop\": \"IsEmpty\"\r\n    }\r\n  ]\r\n}\r\n\r\nInput:
